    <item>
      <title>如何学好日语[7]: 教材《いろどり》笔记</title>
      <link>https://yuuniji.github.io/posts/how-to-learn-japanese-effectively-7-textbook-irodori-notes/</link>
      <pubDate>Fri, 09 May 2025 00:00:00 +0000</pubDate>
      <guid>https://yuuniji.github.io/posts/how-to-learn-japanese-effectively-7-textbook-irodori-notes/</guid>
      <description>&lt;h2 id=&#34;入门&#34;&gt;★《入门》&lt;/h2&gt;
&lt;h3 id=&#34;方式1&#34;&gt;◇方式1&lt;/h3&gt;
&lt;style&gt;

  .player-container {
     
    padding: 15px;
    border-radius: 8px;
    margin-bottom: 20px;
  }

  #audio-player-controls {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
  }

  .sbutton {
     
     
    border: none;
    padding: 8px 12px;
    margin-right: 8px;
    border-radius: 4px;
    cursor: pointer;
    font-size: 14px;
  }

  .sbutton:hover {
    background-color: #4CAF50;
  }

  .sbutton:disabled {
    background-color: #cccccc;
    cursor: not-allowed;
  }

  .rate-btn {
    background-color: #6c757d;
  }

  .rate-btn.active {
    background-color: #28a745;
    font-weight: bold;
  }

  #audio-status {
    margin-left: 10px;
    font-size: 14px;
     
  }

  audio {
    width: 100%;
    margin-top: 10px;
  }


  .note {
    color: #4CAF50;
    font-weight: bold;
    border-bottom: 1px dotted #4CAF50;
    cursor: help;
    position: relative;
  }

  .note:hover::after {
    content: attr(data-note);
    position: absolute;
    bottom: 100%;
    left: 0;
    background-color: #4CAF50;
    color: white;
    padding: 5px;
    border-radius: 4px;
    font-size: 12px;
    white-space: nowrap;
    z-index: 1;
  }

  #navigation {
    display: flex;
    align-items: center;
    margin-bottom: 10px;
  }

  #jump-container {
    margin-left: auto;
    display: flex;
    align-items: center;
  }

  #jump-to {
    padding: 8px;
    margin-right: 8px;
    border: 1px solid #ccc;
    border-radius: 4px;
    width: 200px;
  }

  .lesson-header {
    margin-top: 0;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid #4a6fa5;
     
  }

  #track-info {
    margin-bottom: 15px;
    font-size: 14px;
     
  }

  .keyboard-shortcuts {
    margin-top: 20px;
    font-size: 14px;
     
     
    padding: 10px;
    border-radius: 5px;
  }

  .keyboard-shortcuts kbd {
     
    border-radius: 3px;
    border: 1px solid #b4b4b4;
    box-shadow: 0 1px 1px rgba(0, 0, 0, .2);
     
    display: inline-block;
    font-size: 12px;
    font-family: monospace;
    line-height: 1;
    padding: 2px 4px;
    white-space: nowrap;
  }
&lt;/style&gt;

&lt;div class=&#34;player-container&#34;&gt;
  &lt;div id=&#34;navigation&#34;&gt;
    &lt;div&gt;
      &lt;span id=&#34;current-track&#34;&gt;1&lt;/span&gt; / &lt;span id=&#34;total-tracks&#34;&gt;0&lt;/span&gt;
    &lt;/div&gt;
    &lt;div id=&#34;jump-container&#34;&gt;
      &lt;input type=&#34;text&#34; id=&#34;jump-to&#34; placeholder=&#34;Search or enter track number&#34; list=&#34;tracks-list&#34; style=&#34;color: #A0A0A0;&#34;&gt;
      &lt;datalist id=&#34;tracks-list&#34;&gt;&lt;/datalist&gt;
      &lt;button class=&#34;sbutton&#34; id=&#34;jump-btn&#34;&gt;➡️&lt;/button&gt;
    &lt;/div&gt;
  &lt;/div&gt;

  &lt;div id=&#34;audio-player-controls&#34;&gt;
    &lt;button class=&#34;sbutton&#34; id=&#34;play-btn&#34;&gt;▶️&lt;/button&gt;
    &lt;button class=&#34;sbutton&#34; id=&#34;pause-btn&#34; style=&#34;display:none;&#34;&gt;⏸️&lt;/button&gt;
    &lt;button class=&#34;sbutton&#34; id=&#34;prev-btn&#34;&gt;⏮️&lt;/button&gt;
    &lt;button class=&#34;sbutton&#34; id=&#34;next-btn&#34;&gt;⏭️&lt;/button&gt;
    &lt;button class=&#34;sbutton&#34; id=&#34;rate-1x-btn&#34; class=&#34;rate-btn&#34;&gt;🐌&lt;/button&gt;
    &lt;button class=&#34;sbutton&#34; id=&#34;rate-2x-btn&#34; class=&#34;rate-btn active&#34;&gt;⚡️&lt;/button&gt;
    &lt;span id=&#34;audio-status&#34;&gt;&lt;/span&gt;
  &lt;/div&gt;

  &lt;div id=&#34;track-info&#34;&gt;&lt;/div&gt;
  &lt;audio id=&#34;main-audio&#34; controls&gt;&lt;/audio&gt;
&lt;/div&gt;

&lt;table id=&#34;transcript-table&#34;&gt;
  &lt;thead&gt;
    &lt;tr&gt;
      &lt;th&gt;Japanese&lt;/th&gt;
      &lt;th&gt;Romaji&lt;/th&gt;
      &lt;th&gt;English&lt;/th&gt;
      &lt;th&gt;Chinese&lt;/th&gt;
    &lt;/tr&gt;
  &lt;/thead&gt;
  &lt;tbody id=&#34;transcript-body&#34;&gt;
    
  &lt;/tbody&gt;
&lt;/table&gt;

&lt;div class=&#34;keyboard-shortcuts&#34;&gt;
  &lt;p&gt;&lt;strong&gt;Keyboard shortcuts:&lt;/strong&gt;
    &lt;kbd&gt;→&lt;/kbd&gt; Next track |
    &lt;kbd&gt;←&lt;/kbd&gt; Previous track |
    &lt;kbd&gt;1&lt;/kbd&gt; 1x speed |
    &lt;kbd&gt;2&lt;/kbd&gt; 2x speed
  &lt;/p&gt;</description>
